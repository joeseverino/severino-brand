{
  "_note": "Severino brand tokens. brand = identity; designSystem = the type, space, motion, and color system. Shaped on jseverino.com, owned here.",
  "brand": {
    "navy": "#1E3A8A",
    "navyDeep": "#14245C",
    "onNavy": "#ffffff",
    "card": {
      "textMuted": "#A9C0E8",
      "accent": "#5B82D6",
      "textSoft": "#DDE6FB"
    },
    "glyph": "JS"
  },
  "designSystem": {
    "--color-bg": "#ffffff",
    "--color-text": "#0b0620",
    "--color-text-alt": "#4C63A0",
    "--color-soft": "#eff3fb",
    "--color-muted": "#6E6B7C",
    "--color-border": "color-mix(in oklch, var(--color-text) 8%, transparent)",
    "--color-border-faint": "rgb(0 0 0 / 5%)",
    "--color-fill-faint": "rgb(0 0 0 / 4%)",
    "--color-fill-faint-strong": "rgb(0 0 0 / 8%)",
    "--color-code-bg": "#f8fafc",
    "--color-code-text": "#0f172a",
    "--color-code-border": "rgb(15 23 42 / 14%)",
    "--color-field-border": "rgb(15 23 42 / 18%)",
    "--color-table-stripe": "color-mix(in oklch, var(--color-primary) 5%, transparent)",
    "--color-table-head": "color-mix(in oklch, var(--color-primary) 9%, transparent)",
    "--code-bg": "#020617",
    "--code-fg": "#d1d5db",
    "--term-bg": "#0b1220",
    "--term-fg": "#e2e8f0",
    "--term-bar-bg": "#111827",
    "--term-bar-fg": "#94a3b8",
    "--term-border": "rgb(148 163 184 / 12%)",
    "--term-prompt": "#38bdf8",
    "--term-cmd": "#f8fafc",
    "--term-out": "#4ade80",
    "--term-dot-red": "#ef4444",
    "--term-dot-amber": "#f59e0b",
    "--term-dot-green": "#22c55e",
    "--color-success": "#166534",
    "--color-success-bg": "rgb(22 101 52 / 10%)",
    "--color-error": "#991b1b",
    "--color-error-bg": "rgb(153 27 27 / 10%)",
    "--shadow-sm": "0 6px 10px rgb(0 0 0 / 18%)",
    "--shadow-md": "0 10px 16px rgb(0 0 0 / 22%)",
    "--blur-chrome": "12px",
    "--motion-duration-instant": "120ms",
    "--motion-duration-fast": "150ms",
    "--motion-duration-standard": "200ms",
    "--motion-duration-deliberate": "220ms",
    "--motion-stagger-step": "55ms",
    "--motion-ease-standard": "ease",
    "--radius-sm": "10px",
    "--radius-md": "12px",
    "--radius-pill": "999px",
    "--radius-button": "2rem",
    "--content": "42rem",
    "--wide": "80rem",
    "--cards": "1100px",
    "--gutter": "clamp(1.5rem, 6vw, 2rem)",
    "--w-constrained": "min(var(--content), calc(100% - (var(--gutter) * 2)))",
    "--w-wide": "min(var(--wide), calc(100% - (var(--gutter) * 2)))",
    "--font-mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace",
    "--space-20": "1rem",
    "--space-30": "clamp(1.5rem, 6vw, 2rem)",
    "--space-40": "clamp(2rem, 8vw, 3rem)",
    "--space-50": "clamp(2.5rem, 8vw, 4rem)",
    "--font-xs": "clamp(14px, 0.875rem + ((1vw - 3.2px) * 0.208), 16px)",
    "--font-sm": "1rem",
    "--font-base": "clamp(0.875rem, 0.875rem + ((1vw - 0.2rem) * 0.417), 1.125rem)",
    "--font-md": "1.25rem",
    "--font-lg": "clamp(1.25rem, 1.25rem + ((1vw - 0.2rem) * 0.833), 1.75rem)",
    "--font-xl": "clamp(1.39rem, 1.39rem + ((1vw - 0.2rem) * 1.433), 2.25rem)",
    "--font-xxl": "clamp(1.5rem, 1.5rem + ((1vw - 0.2rem) * 2.5), 3rem)",
    "--font-prose-sm": "clamp(1.25rem, 1.25rem + ((1vw - 0.2rem) * 0.417), 1.5rem)",
    "--font-prose-md": "clamp(1.5rem, 1.5rem + ((1vw - 0.2rem) * 0.625), 1.875rem)",
    "--header-height": "3.6rem"
  }
}
