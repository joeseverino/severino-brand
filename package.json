{
  "name": "severino-brand",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Joe Severino's brand: the data (mark, palette, type, voice) plus generated kits. Rendered by branding-engine.",
  "scripts": {
    "build": "branding-engine build --config brand --out kits",
    "kit": "branding-engine kit",
    "figure": "branding-engine figure",
    "describe": "node bin/brand --describe",
    "describe:write": "node bin/brand --write",
    "pictograms": "branding-engine pictogram --spec brand/pictograms.json --out kits/pictograms"
  },
  "dependencies": {
    "branding-engine": "^0.4.0"
  },
  "packageManager": "pnpm@10.34.4+sha512.8768be55200ae3f2226b6527fcca2687e14bc4e5f12d7721a0f25da3df47915177058648db4177baf348120fa0ba2752d8d8d93f6beaf1fe64ae18da8de961af",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "cordon-spec": "1.3.0"
  }
}
